#!/usr/bin/env bash
set -euo pipefail
PROJECT_DIR="$(cd -- "$(dirname "${BASH_SOURCE}")" ; cd ../.. > /dev/null 2>&1 && pwd -P)"
TOOL_VERSIONS_FILE="$PROJECT_DIR/.tool-versions"
REQUIRED_RUBY_VERSION=""

if [[ -f "$TOOL_VERSIONS_FILE" ]]; then
  REQUIRED_RUBY_VERSION="$(awk '$1 == "ruby" { print $2; exit }' "$TOOL_VERSIONS_FILE")"
fi

source "$PROJECT_DIR/bin/env/select-tool-versions-manager"

case "$TOOL_VERSIONS_MANAGER" in
  asdf|asdf-vm)
    echo "Setting up ruby via asdf"
    ASDF_PLUGIN=ruby
    ASDF_PLUGIN_URL=https://github.com/asdf-vm/asdf-ruby.git
    source "$PROJECT_DIR/bin/env/asdf-helper.bash"
    asdf-update-plugin
    if [[ -n "$REQUIRED_RUBY_VERSION" ]]; then
      export ASDF_RUBY_VERSION="$REQUIRED_RUBY_VERSION"
      asdf install ruby "$REQUIRED_RUBY_VERSION"
      ruby_install_dir="$(asdf where ruby "$REQUIRED_RUBY_VERSION" 2>/dev/null || true)"
      ruby_bin="${ruby_install_dir}/bin/ruby"
      if [[ -z "${ruby_install_dir}" || ! -x "${ruby_bin}" ]]; then
        echo "WARNING: ruby $REQUIRED_RUBY_VERSION marked installed but binary missing; reinstalling"
        asdf uninstall ruby "$REQUIRED_RUBY_VERSION" || true
        asdf install ruby "$REQUIRED_RUBY_VERSION"
      fi
      # Ensure ruby shim reflects the newly active version in CI shells.
      asdf reshim ruby "$REQUIRED_RUBY_VERSION"
    else
      asdf install ruby
      asdf reshim ruby
    fi
    ;;
  mise)
    echo "Setting up ruby via mise"
    if [[ -n "$REQUIRED_RUBY_VERSION" ]]; then
      export MISE_RUBY_VERSION="$REQUIRED_RUBY_VERSION"
      mise install ruby@"$REQUIRED_RUBY_VERSION"
    else
      mise install ruby
    fi
    ;;
  *)
    echo "ERROR: Unsupported TOOL_VERSIONS_MANAGER: $TOOL_VERSIONS_MANAGER"
    exit 1
    ;;
esac

