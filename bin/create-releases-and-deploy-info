#!/usr/bin/env bash
set -euo pipefail

MADEK_DIR="$(cd -- "$(dirname "${BASH_SOURCE}")" ; cd .. > /dev/null 2>&1 && pwd -P)"
source "$MADEK_DIR/bin/env/ruby-setup"

cd "$MADEK_DIR"

if command -v asdf >/dev/null 2>&1 && [[ -f "$MADEK_DIR/.tool-versions" ]]; then
  required_ruby_version="$(awk '$1 == "ruby" { print $2; exit }' "$MADEK_DIR/.tool-versions")"
  if [[ -n "${required_ruby_version:-}" ]]; then
    export ASDF_RUBY_VERSION="$required_ruby_version"
    asdf install ruby "$required_ruby_version"
    asdf reshim ruby "$required_ruby_version"
  fi
fi

if command -v asdf >/dev/null 2>&1; then
  ASDF_RUBY_VERSION="${required_ruby_version:-}" asdf exec ruby "$MADEK_DIR/bin/deploy_info.rb"
  ASDF_RUBY_VERSION="${required_ruby_version:-}" asdf exec ruby "$MADEK_DIR/dev/releasenotes-md-to-yaml.rb"
else
  ASDF_RUBY_VERSION="${required_ruby_version:-}" ruby "$MADEK_DIR/bin/deploy_info.rb"
  ASDF_RUBY_VERSION="${required_ruby_version:-}" ruby "$MADEK_DIR/dev/releasenotes-md-to-yaml.rb"
fi
