#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd -- "$(dirname "${BASH_SOURCE}")" ; cd .. > /dev/null 2>&1 && pwd -P)"
cd "${PROJECT_DIR}"

BRANCH=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --branch) BRANCH="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

if [[ -z "$BRANCH" ]]; then
  read -rp "Branch name [mk/ci]: " BRANCH
  BRANCH="${BRANCH:-mk/ci}"
fi

# <submodule_path>:<datalayer_submodule_path>
SUBMODULES=(
  "admin-webapp:datalayer"
  "api:datalayer"
  "api-v2:datalayer"
  "auth:datalayer"
  "mail:datalayer"
  "webapp:datalayer"
)

for entry in "${SUBMODULES[@]}"; do
  SM="${entry%%:*}"
  DL_PATH="${entry##*:}"

  echo "=== $SM/$DL_PATH ==="
  cd "${PROJECT_DIR}/${SM}/${DL_PATH}"
  git push --force origin "HEAD:refs/heads/${BRANCH}"

  echo "=== $SM ==="
  cd "${PROJECT_DIR}/${SM}"
  git push --force origin "HEAD:refs/heads/${BRANCH}"
done

echo "=== main repo ==="
cd "${PROJECT_DIR}"
git push --force origin "HEAD:refs/heads/${BRANCH}"
