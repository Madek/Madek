#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd -- "$(dirname "${BASH_SOURCE}")" ; cd .. > /dev/null 2>&1 && pwd -P)"
cd "${PROJECT_DIR}"

# Submodules that contain a datalayer sub-submodule: "<submodule_path>:<datalayer_path>"
SUBMODULES=(
  "admin-webapp:datalayer"
  "api:datalayer"
  "api-v2:datalayer"
  "auth:datalayer"
  "mail:datalayer"
  "webapp:datalayer"
)

usage() {
  echo "Usage: $0 [--dl-ref <ref>] [--branch <branch>] [--base-ref <ref>] [--message <message>] [--dry-run]"
  echo ""
  echo "  --dl-ref   <ref>     datalayer ref to checkout (commit/branch/tag)"
  echo "  --branch   <name>    branch name to use in all submodules and main repo"
  echo "  --base-ref <ref>     base ref to reset branch to before commit"
  echo "  --message  <msg>     commit message"
  echo "  --dry-run            show what would happen, make no changes"
  exit 1
}

DL_REF=""
BRANCH=""
BASE_REF=""
MESSAGE=""
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dl-ref)   DL_REF="$2";   shift 2 ;;
    --branch)   BRANCH="$2";   shift 2 ;;
    --base-ref) BASE_REF="$2"; shift 2 ;;
    --message)  MESSAGE="$2";  shift 2 ;;
    --dry-run)  DRY_RUN=true;  shift ;;
    -h|--help)  usage ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

run() {
  if $DRY_RUN; then
    echo "  [dry-run] $*"
  else
    "$@"
  fi
}

# Prompt for any missing values
if [[ -z "$DL_REF" ]]; then
  read -rp "Datalayer ref (commit/branch/tag): " DL_REF
fi

if [[ -z "$BRANCH" ]]; then
  read -rp "Branch name for submodules and main repo: " BRANCH
fi

if [[ -z "$BASE_REF" ]]; then
  read -rp "Base ref to reset branch to [origin/master]: " BASE_REF
  BASE_REF="${BASE_REF:-origin/master}"
fi

# Fetch and get default message from datalayer commit
git -C datalayer fetch origin
DL_COMMIT_MSG=$(git -C datalayer log -1 --format=%B "$DL_REF" | head -1)
DEFAULT_MESSAGE="datalayer: ${DL_COMMIT_MSG}"

if [[ -z "$MESSAGE" ]]; then
  read -rp "Commit message [$DEFAULT_MESSAGE]: " MESSAGE
  MESSAGE="${MESSAGE:-$DEFAULT_MESSAGE}"
fi

echo ""
echo "  dl-ref:   $DL_REF"
echo "  branch:   $BRANCH"
echo "  base-ref: $BASE_REF"
echo "  message:  $MESSAGE"
echo ""

# Update top-level datalayer submodule (no branch reset, just pointer update)
echo "=== datalayer (top-level) ==="
TARGET_SHA=$(git -C datalayer rev-parse "$DL_REF")
CURRENT_SHA=$(git -C datalayer rev-parse HEAD)
if [[ "$TARGET_SHA" == "$CURRENT_SHA" ]]; then
  echo "  already at $TARGET_SHA, skipping"
else
  run git -C datalayer checkout "$DL_REF"
fi

# Update each submodule: reset branch to origin/master, update datalayer, commit
for entry in "${SUBMODULES[@]}"; do
  SUBMOD="${entry%%:*}"
  DL_PATH="${entry##*:}"

  echo "=== $SUBMOD ==="
  cd "${PROJECT_DIR}/${SUBMOD}"

  git -C "$DL_PATH" fetch origin

  TARGET_SHA=$(git -C "$DL_PATH" rev-parse "$DL_REF")
  CURRENT_SHA=$(git -C "$DL_PATH" rev-parse HEAD)

  if [[ "$TARGET_SHA" == "$CURRENT_SHA" ]]; then
    echo "  already at $TARGET_SHA, skipping"
    cd "${PROJECT_DIR}"
    continue
  fi

  git fetch origin
  run git checkout -B "$BRANCH" "$BASE_REF"

  run git -C "$DL_PATH" checkout "$DL_REF"

  run git add "$DL_PATH"
  run git commit -m "$MESSAGE"

  cd "${PROJECT_DIR}"
done

# Commit everything in main repo
echo "=== main repo ==="
run git add datalayer
for entry in "${SUBMODULES[@]}"; do
  run git add "${entry%%:*}"
done
run git commit -m "$MESSAGE"

echo ""
if $DRY_RUN; then
  echo "[dry-run] would ask to push updated submodule branches"
else
  read -rp "Push updated submodule branches? [Y/n]: " PUSH_ANSWER
  if [[ "${PUSH_ANSWER,,}" != "n" ]]; then
    bin/push-datalayer-submodule-branches --branch "$BRANCH"
  else
    echo "Skipped. To push manually:"
    echo "  bin/push-datalayer-submodule-branches --branch $BRANCH"
  fi
fi
